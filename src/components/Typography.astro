---
export interface Props {
  type: "heading" | "paragraph" | "span";
  level?: 1 | 2 | 3 | 4;
}

const { type, level = 1 } = Astro.props;

const Tag = type === "heading" ? `h${level}` : type === "paragraph" ? "p" : "span";

const headingClasses = {
  1: "transition-colors text-3xl font-semibold text-zinc-950 dark:text-white flex items-start gap-x-[1px]",
  2: "transition-colors text-2xl font-semibold text-zinc-950 dark:text-white",
  3: "transition-colors text-xl font-semibold text-zinc-950 dark:text-white",
  4: "transition-colors text- font-semibold text-zinc-950 dark:text-white"
}
const paragraphClass = "transition-colors text-zinc-700 dark:text-zinc-300 pt-2 text-pretty";
const spanClass = "font-medium transition-colors text-zinc-950 dark:text-white";

const className = type === "heading" ? headingClasses[level] : type === "paragraph" ? paragraphClass : spanClass;
---

<Tag class:list={className}>
  <slot />
</Tag>